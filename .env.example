# .env.example
DB_USER=your_db_user_here
DB_PASSWORD=your_secure_password_here
DB_NAME=espocrm_db

# N8N Encryption Key generated by running `openssl rand -base64 32`
N8N_ENCRYPTION_KEY=generate_a_random_string_here

# System Configuration (Required for Let's Encrypt SSL)
# strictly used by Let's Encrypt for one specific purpose: Expiration and Security Alerts.
ACME_EMAIL=<email-address>

# Live Production Domains
N8N_DOMAIN=n8n.yourdomain.com
CRM_DOMAIN=crm.yourdomain.com
PORTAINER_DOMAIN=portainer.yourdomain.com
STATUS_DOMAIN=status.yourdomain.com
